            android:value="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJhZG1pbiIsImV4cCI6OTk5OTk5OTk5OX0" />

        <!-- Service avec authentification -->
        <service
            android:name="com.vulnerable.service.SecureService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.vulnerable.SECURE_API" />
                <data android:scheme="https" android:host="api.internal.company.com" />
            </intent-filter>
        </service>

        <!-- Broadcast Receiver avec secret -->
        <receiver
            android:name="com.vulnerable.receiver.AuthReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.vulnerable.AUTH_CHECK" />
                <data android:scheme="secure" android:host="admin@company.com" />
            </intent-filter>
        </receiver>

        <!-- Activity principale -->
        <activity
            android:name="com.vulnerable.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Strings ressources contenant des secrets -->
        <string name="api_endpoint">https://api.internal-server.com/v2/secure?token=sk_live_secret_123</string>
