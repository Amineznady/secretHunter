    <application
        android:allowBackup="true"
        android:debuggable="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <!-- Meta-data avec clés API -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDx-wNqRsPc7VwhQZqFeXzM0xVfYnWmWNY" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />

        <!-- Secrets dans les meta-data -->
        <meta-data
            android:name="STRIPE_API_KEY"
            android:value="sk_live_YOUR_FAKE_STRIPE_KEY_HERE_12345FAKE" />

        <meta-data
            android:name="DATABASE_PASSWORD"
            android:value="DbAdmin@2025!Secure" />

